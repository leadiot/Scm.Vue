# 版本代码，根据需要修改，当前应用的版本号
VITE_APP_VER = 10.10.20

# 构建日期，根据需要修改，格式为YYYYMMDD-No，当前应用的构建日期
VITE_APP_BUILD = 2026033001

# 应用代码，根据需要修改，当前应用的应用代码
VITE_APP_CODE = Scm.Net

# OIDC 应用KEY，不能修改，否则外部登录页面无法打开
VITE_APP_OIDC_KEY = 08dc965832db7248

# OIDC 应用服务路径，不能修改，否则外部登录页面无法打开
VITE_APP_OIDC_OSP = https://oidc.org.cn/oauth/apposp/

# OIDC 应用图标，不能修改，否则服务图标显示异常
VITE_APP_OIDC_LOGO = https://oidc.org.cn/data/logo/

# OIDC 授权路径，不能修改，否则外部授权页面无法打开
VITE_APP_OIDC_AUTH = https://oidc.org.cn/oauth/login/{osp}?app_key={key}&state={state}

# OIDC 绑定路径，不能修改，否则外部授权页面无法打开
VITE_APP_OIDC_BIND = https://oidc.org.cn/oauth/index?key={key}&state={state}

# OIDC 登录路径，不能修改，否则外部登录页面无法打开
VITE_APP_OIDC_LOGIN = https://www.oidc.org.cn/web/login?client_id={key}&state={state}
